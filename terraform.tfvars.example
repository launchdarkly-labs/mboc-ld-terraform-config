# LaunchDarkly API Configuration
# Copy this file to terraform.tfvars and add your actual API token

launchdarkly_access_token = "your-launchdarkly-api-token-here"
view_maintainer_id = "your-launchdarkly-member-id-here"
team_maintainer_id = "your-launchdarkly-member-id-here"

# Optional: Override the placeholder Projects and Products from variables.tf.
# If not specified, the default placeholder values will be used.
# See README.md for full details.
#
# Set managed = false on a project to exclude it (and all its products) from
# Terraform. This is useful when those resources are managed via the LD UI and
# you want to avoid conflicts.
#
# projects = {
#   payments = {
#     name = "Payments Platform"
#   }
#   checkout = {
#     name    = "Checkout Experience"
#     managed = false  # managed via UI, excluded from Terraform
#   }
# }
#
# products = {
#   payments_api = {
#     name        = "Payments API"
#     project_key = "payments"
#   }
#   fraud_detection = {
#     name        = "Fraud Detection"
#     project_key = "payments"
#   }
#   cart = {
#     name        = "Shopping Cart"
#     project_key = "checkout"  # automatically excluded because checkout is unmanaged
#   }
# }
